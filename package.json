{
  "name": "youtube-private-share-server",
  "version": "1.0.0",
  "description": "REST API server that runs Playwright automation to add invitees to private YouTube Studio videos.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "agent": "node agent/index.js claim-and-run",
    "interactive-login": "node scripts/interactiveLogin.js",
    "save-storage-state-from-chrome": "node scripts/saveStorageStateFromChrome.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
