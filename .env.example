PORT=3000
ADMIN_TOKEN=change-me
# 배포 프론트와 로컬 개발 서버 Origin을 쉼표로 구분해 허용합니다.
ALLOWED_ORIGINS=https://youtube-private-video-share.netlify.app,http://localhost:5173
STORAGE_STATES_DIR=./data/storageStates
CONNECTIONS_DIR=./data/connections
LOGIN_SESSIONS_DIR=./data/loginSessions
ARTIFACTS_DIR=./data/artifacts
JOBS_DIR=./data/jobs
TMP_DIR=./data/tmp
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_LOGIN_CHANNEL=chrome
PLAYWRIGHT_LOGIN_BROWSER_PATH=
PLAYWRIGHT_LOGIN_USE_SYSTEM_PROFILE=false
PLAYWRIGHT_LOGIN_PROFILE_DIRECTORY=Default
PLAYWRIGHT_LOGIN_CHROMIUM_SANDBOX=true
DEFAULT_LOCALE=auto
JOB_HISTORY_LIMIT=100
JOB_POLL_INTERVAL_MS=500
LOGIN_SESSION_TTL_MS=900000
GOOGLE_SIGNIN_URL=https://accounts.google.com/signin/v2/identifier?service=youtube
AGENT_ID=local-agent
AGENT_SERVER_BASE_URL=http://localhost:3000
AGENT_POLL_INTERVAL_MS=3000
AGENT_RUN_ONCE=false
